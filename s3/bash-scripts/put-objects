#!/usr/bin/env bash

# Where we'll store these files
OUTPUT_DIR="/tmp/s3-bash-scripts"

# Lets create the output folder
mkdir -p $OUTPUT_DIR

# Generate a random number between 5 and 10
# (RANDOM % 6) gives 0-5, then we add 5 to get 5-10
NUM_FILES=$((RANDOM % 6 + 5))

# Start a loop
for ((i=1; i<=NUM_FILES; i++)); do
    # Generate a random filename
    FILENAME="$OUTPUT_DIR/file_$i.txt"

    # Generate random data and write it to the file
    # 'dd' is a tool that writes raw data
    # 'if' is the source (urandom is random junk data)
    # 'of' is the output file
    # 'bs=1024' is block size (1KB)
    # 'count' is how many blocks
    dd if=/dev/urandom of="$FILENAME" bs=1024 count=$((RANDOM % 1024 + 1)) 2>/dev/null
done

# Show the results
tree $OUTPUT_DIR