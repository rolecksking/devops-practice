#!/usr/bin/env bash

echo "== delete bucket"

# 1. Check if a bucket name was provided
if [ -z "$1" ]; then
    echo "Error: You need to provide the name of the bucket to delete."
    echo "Usage: ./delete-bucket <bucket-name>"
    exit 1
fi

BUCKET_NAME=$1

# 2. Confirm the action (Safety First!)
echo "Are you sure you want to delete the bucket: $BUCKET_NAME? (y/n)"
read -r response

if [ "$response" != "y" ]; then
    echo "Deletion cancelled."
    exit 0
fi

# 3. Delete the bucket
echo "Deleting bucket: $BUCKET_NAME..."
aws s3api delete-bucket --bucket "$BUCKET_NAME" --region eu-north-1

echo "Bucket $BUCKET_NAME deleted successfully."